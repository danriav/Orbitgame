# Unity Standard Ignores
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Mm]emoryCaptures/
/Assets/AssetStoreTools*
/UserSettings/

# Project Specific Ignores
DO_Assets/
*.log
unity_create.log
debug_unity.log

# Exclude massive extracted assets (Found ~18GB of files)
# Only keeping _Project and configuration files
ClienteUnity/Assets/*
!ClienteUnity/Assets/_Project/
!ClienteUnity/Assets/*.asset
!ClienteUnity/Assets/*.asset.meta
!ClienteUnity/Assets/*.asmdef
!ClienteUnity/Assets/*.asmdef.meta

